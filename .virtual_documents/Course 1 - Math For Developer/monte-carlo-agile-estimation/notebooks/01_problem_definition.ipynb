#For this experiment I will use the Empirical Cumulative Distribution Function (ECDF) to represent the integration as per the data from Jira


import numpy as np
import matplotlib.pyplot as plt

# Set matplotlib style
plt.rcParams['figure.figsize'] = (14, 8)
plt.rcParams['font.size'] = 11

# Your actual integration data
integration_actual_days = [
    3,3,16,24,12,9,42,19,36,21,71,55,29,32,1,35,65,46,53,46,21,29,34,25,40,2,77,6,37,1,38,21,29,27,30,67,41,49,29,44,36,1,25,22,22,55,15
]

point_estimate = 10  # The "M" estimate (2 weeks)

# print("="*70)
# print("INTEGRATION DATA SUMMARY")
# print("="*70)
# print(f"Number of integrations: {len(integration_actual_days)}")
# print(f"Point estimate: {point_estimate} days")
# print(f"Actual mean: {np.mean(integration_actual_days):.1f} days")
# print(f"Actual median: {np.median(integration_actual_days):.1f} days")
# print(f"Actual std dev: {np.std(integration_actual_days, ddof=1):.1f} days")
# print(f"Range: {np.min(integration_actual_days)} - {np.max(integration_actual_days)} days")
# print("="*70)

# # ============================================================
# # Step 1: Build Empirical CDF from scratch (no special libraries)
# # ============================================================
# # The empirical CDF is simple: for each value x, count how many 
# # data points are ≤ x, then divide by total number of points

# Sort the data
sorted_data = np.sort(integration_actual_days)
n = len(sorted_data)

# For each data point, the CDF value is: (number of points ≤ this value) / n
# Since data is sorted, the i-th point has i points ≤ it
empirical_cdf_values = np.arange(1, n + 1) / n

# For plotting a smooth curve, we'll create many x values
x_range = np.linspace(0, 35, 1000)

# For each x, count how many data points are ≤ x
empirical_cdf_smooth = np.zeros_like(x_range)
for i, x in enumerate(x_range):
    # Count how many integration times are ≤ x
    count = np.sum(np.array(integration_actual_days) <= x)
    empirical_cdf_smooth[i] = count / n

# ============================================================
# Step 2: Create point estimate CDF (step function)
# ============================================================
# Before day 10: probability = 0
# Day 10 and after: probability = 1
point_estimate_cdf = np.where(x_range >= point_estimate, 1.0, 0.0)

# ============================================================
# Step 3: Calculate key statistics
# ============================================================
# Probability of finishing by the point estimate
prob_at_estimate = np.sum(np.array(integration_actual_days) <= point_estimate) / n

# Median (50th percentile)
median_day = np.median(integration_actual_days)

# 85th percentile
p85_day = np.percentile(integration_actual_days, 85)

# print(f"\nKEY PROBABILITIES:")
# print(f"Probability of finishing by day {point_estimate}: {prob_at_estimate*100:.1f}%")
# print(f"Day when 50% are done (median): {median_day:.0f} days")
# print(f"Day when 85% are done (P85): {p85_day:.0f} days")
# print("="*70)

# ============================================================
# Step 4: Create the visualization
# ============================================================
fig, ax = plt.subplots(figsize=(14, 8))

# Plot the empirical CDF (smooth)
ax.plot(x_range, empirical_cdf_smooth, linewidth=3, color='steelblue', 
        label='Reality (Empirical CDF)', zorder=3)

# Plot the point estimate CDF (step function)
ax.plot(x_range, point_estimate_cdf, linewidth=3, color='red', 
        linestyle='--', label='Point Estimate CDF', zorder=2)

# Add vertical line at point estimate
ax.axvline(point_estimate, color='red', linestyle=':', linewidth=2, 
           alpha=0.5, zorder=1)

# Add horizontal line at 50% probability
ax.axhline(0.5, color='gray', linestyle=':', linewidth=1.5, 
           alpha=0.4, label='50% probability', zorder=1)

# Highlight the key point: probability at point estimate
# Find the CDF value at point_estimate
idx_estimate = np.argmin(np.abs(x_range - point_estimate))
cdf_at_estimate = empirical_cdf_smooth[idx_estimate]

ax.plot([point_estimate], [cdf_at_estimate], 'ro', markersize=12, zorder=4)

# Add annotation showing the problem
ax.annotate(f'Only {prob_at_estimate*100:.1f}% done by day {point_estimate}', 
            xy=(point_estimate, cdf_at_estimate), 
            xytext=(point_estimate + 5, cdf_at_estimate - 0.15),
            arrowprops=dict(arrowstyle='->', color='red', lw=2.5),
            fontsize=13, color='red', fontweight='bold',
            bbox=dict(boxstyle='round,pad=0.5', facecolor='yellow', alpha=0.7))

# Add vertical lines showing median and P85
ax.axvline(median_day, color='green', linestyle='--', linewidth=2, 
           alpha=0.6, label=f'Actual Median: {median_day:.0f} days')
ax.axvline(p85_day, color='orange', linestyle='--', linewidth=2, 
           alpha=0.6, label=f'85th Percentile: {p85_day:.0f} days')

# Mark the median and P85 on the CDF curve
idx_median = np.argmin(np.abs(x_range - median_day))
idx_p85 = np.argmin(np.abs(x_range - p85_day))
ax.plot([median_day], [empirical_cdf_smooth[idx_median]], 'go', markersize=10, zorder=4)
ax.plot([p85_day], [empirical_cdf_smooth[idx_p85]], 'o', color='orange', markersize=10, zorder=4)

# Labels and title
ax.set_xlabel('Days', fontsize=14, fontweight='bold')
ax.set_ylabel('Cumulative Probability', fontsize=14, fontweight='bold')
ax.set_title('Cumulative Distribution Function (CDF)\n"What % of integrations finish by day X?"', 
             fontsize=16, fontweight='bold', pad=20)

# Set limits
ax.set_xlim(0, 35)
ax.set_ylim(0, 1.05)

# Grid
ax.grid(alpha=0.3, linewidth=0.5)

# Legend
ax.legend(fontsize=11, loc='lower right', framealpha=0.9)

